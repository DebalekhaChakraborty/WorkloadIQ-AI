GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_GENAI_USE_VERTEXAI="True"

TICKET_QA_OUTPUT_DIR="./outputs"
TICKET_QA_MODEL="gemini-2.5-flash"
TICKET_QA_PASS_THRESHOLD="70"
TICKET_QA_FATAL_THRESHOLD="0"

HEAVY_HITTER_LLM_MODEL="gemini-2.5-flash"
HEAVY_HITTER_TOP_N="10"
HEAVY_HITTER_SAMPLE_ROWS="30"

NORMALIZE_LLM_MODEL="gemini-2.5-flash"

HOST="0.0.0.0"
PORT="8000"
SERVER_TIMEOUT_KEEP_ALIVE="600"
# Comma-separated literal origins or ADK "regex:" entries.
# The server defaults already allow localhost and RFC1918 Linux dev hosts on ports 3000/5173.
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000,regex:^http://(?:10\.\d+\.\d+\.\d+|192\.168\.\d+\.\d+|172\.(?:1[6-9]|2\d|3[01])\.\d+\.\d+):(?:3000|5173)$"

COPILOT_USE_ADK="True"
ADK_INTERNAL_BASE_URL="http://127.0.0.1:8000"
ADK_CONNECT_TIMEOUT_SECONDS="5"
ADK_CHAT_TIMEOUT_SECONDS="120"
